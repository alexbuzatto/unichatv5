<li class="px-4 mb-1">
  <% text_class_name = current_page?(url) ? 'text-n-brand bg-n-alpha-2' : 'text-n-slate-11' %>
  <%= link_to(url, class: text_class_name + " -ml-1 focus:outline-none cursor-pointer flex items-center px-2 py-1.5 cursor-pointer hover:text-n-brand hover:bg-n-alpha-2 rounded-lg") do %>
    <svg width="16" height="16"><use xlink:href="#<%= icon %>" /></svg>
    <span class="ml-2 text-sm font-medium"><%= label %></span>
  <% end %>
</li>
